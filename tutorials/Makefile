PROJECT_ROOT := $(abspath $(CURDIR)/..)

.PHONY: ffd-production ffd-manual ising-manual ising-builtin clean

ffd-production:
	$(MAKE) -C "$(PROJECT_ROOT)" ffd-production

ffd-manual:
	$(MAKE) -C "$(PROJECT_ROOT)" ffd-manual

ising-manual:
	$(MAKE) -C "$(PROJECT_ROOT)" ising-manual

ising-builtin:
	$(MAKE) -C "$(PROJECT_ROOT)" ising-builtin

clean:
	$(MAKE) -C "$(PROJECT_ROOT)" clean
